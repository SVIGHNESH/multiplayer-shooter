{
  "name": "multiplayer-shooter",
  "version": "1.0.0",
  "description": "2D top-down multiplayer arena shooter playable in the browser",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "smoke": "node test/smoke.js",
    "test:match": "node test/match.js",
    "test:errors": "node test/errors.js",
    "test:leave": "node test/leave.js",
    "test:host": "node test/host.js",
    "shots": "node test/shots.js",
    "test": "node test/smoke.js && node test/match.js && node test/errors.js && node test/leave.js && node test/host.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "socket.io-client": "^4.7.5"
  }
}
